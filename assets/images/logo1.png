<svg width="200" height="70" viewBox="0 0 200 70" xmlns="http://www.w3.org/2000/svg">

  <!-- Background -->
  <rect width="200" height="70" rx="10" fill="#111111"></rect>

  <!-- Barbell Icon -->
  <g fill="#e5e7eb">
    <rect x="15" y="32" width="40" height="6"></rect>
    <rect x="10" y="28" width="6" height="14"></rect>
    <rect x="54" y="28" width="6" height="14"></rect>
  </g>

  <!-- Tribe Circle -->
  <circle cx="35" cy="20" r="6" fill="#ef4444"></circle>

  <!-- Text: IRONTRIBE -->
  <text x="70" y="32" font-family="Arial, Helvetica, sans-serif" font-size="16" font-weight="700" fill="#f9fafb" letter-spacing="1">
        IRONTRIBE
  </text>

  <!-- Text: CrossFit -->
  <text x="70" y="52" font-family="Arial, Helvetica, sans-serif" font-size="12" fill="#9ca3af">
        CrossFit
  </text>

</svg>
